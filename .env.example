# ==========================================
# AI Studio Configuration File
# Copy this file to .env and fill in the keys
# ==========================================

# 1. Google Gemini API Key (Get it from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Staff Security Keys (Must be at least 10 characters long, no common words)
ADMIN_KEY=change_this_to_a_secure_admin_password_123!
TEACHER_KEY=change_this_to_a_secure_teacher_password_123!

# 3. Server Settings (Optional - these are defaults)
PORT=3000
MODEL=gemini-3.1-flash-image
CHAT_MODEL=gemini-2.5-flash
MAX_IMAGES_PER_STUDENT=5
MAX_IMAGES_PER_SESSION=400
MAX_CHATS_PER_STUDENT=40
MAX_ACTIVE_STUDENTS=60